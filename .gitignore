# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!environments/*.tfvars

# Bootstrap local state is committed — it IS the source of truth for the backend resource
!bootstrap/terraform.tfstate
!bootstrap/terraform.tfstate.backup
crash.log
override.tf
override.tf.json

# Azure credentials - never commit these
*.pem
*.key
.env

